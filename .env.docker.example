# Copy this file to .env.docker or pass it with:
# docker compose --env-file .env.docker up -d

APP_DOMAIN=example.com
APP_NAME=SSPanel-UIM
HTTP_PORT=80

DB_DATABASE=sspanel
DB_USERNAME=sspanel
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# Leave empty to run Redis without authentication in the private Docker network.
REDIS_PASSWORD=

TZ=Asia/Shanghai

# Reserved for the later one-click installer phase.
ADMIN_EMAIL=
ADMIN_PASSWORD=
