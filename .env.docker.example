# Copy this file to .env.docker or pass it with:
# docker compose --env-file .env.docker up -d

APP_DOMAIN=example.com
APP_NAME=SSPanel-UIM
HTTPS_ENABLED=false
HTTP_PORT=80
HTTPS_PORT=443

# Base docker-compose.yml publishes HTTP only. install.sh creates the ignored
# docker-compose.override.yml file to publish HTTPS port 443 when HTTPS is enabled.
# HTTP mode: http://:80
# HTTPS mode: example.com
CADDY_SITE_ADDRESS=http://:80

# Caddy trusts only private proxy hops by default. If a public CDN is placed
# directly in front of Caddy, replace this with that provider's official CIDRs.
CADDY_TRUSTED_PROXIES=private_ranges

# install.sh writes cookie_secure to config/.config.php:
# HTTP mode: false
# HTTPS mode: true
# muKey is prompted by install.sh and written only to config/.config.php.
# Leave the prompt blank to auto-generate it; keep config/.config.php backed up.

DB_DATABASE=sspanel
DB_USERNAME=sspanel
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# Leave empty to run Redis without authentication in the private Docker network.
REDIS_PASSWORD=

TZ=Asia/Shanghai

# Optional PHP-FPM tuning. For small VPS instances, keep conservative defaults.
# Estimate PHP_FPM_MAX_CHILDREN as memory available for PHP divided by about 30 MB.
PHP_FPM_PM=dynamic
PHP_FPM_MAX_CHILDREN=20
PHP_FPM_START_SERVERS=4
PHP_FPM_MIN_SPARE_SERVERS=2
PHP_FPM_MAX_SPARE_SERVERS=8
PHP_FPM_MAX_REQUESTS=500

# Reserved for the later one-click installer phase.
ADMIN_EMAIL=
ADMIN_PASSWORD=
