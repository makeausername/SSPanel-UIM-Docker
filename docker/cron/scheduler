#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-/var/www/html}"
INTERVAL_SECONDS="${CRON_INTERVAL_SECONDS:-300}"
LOCK_DIR="${CRON_LOCK_DIR:-${APP_DIR}/storage/framework/sspanel-cron.lock}"
STALE_AFTER_SECONDS="${CRON_STALE_AFTER_SECONDS:-900}"
HEARTBEAT_FILE="${SCHEDULER_HEARTBEAT_FILE:-${APP_DIR}/storage/framework/scheduler.last_success}"
LOCK_HEARTBEAT_PID=""

if ! [[ "${INTERVAL_SECONDS}" =~ ^[1-9][0-9]*$ ]]; then
    echo "[scheduler] CRON_INTERVAL_SECONDS must be a positive integer" >&2
    exit 64
fi

case "${LOCK_DIR}" in
    "${APP_DIR}"/storage/framework/*) ;;
    *)
        echo "[scheduler] CRON_LOCK_DIR must stay under ${APP_DIR}/storage/framework" >&2
        exit 64
        ;;
esac

cd "${APP_DIR}"

cleanup_lock() {
    if [ -n "${LOCK_HEARTBEAT_PID}" ]; then
        kill "${LOCK_HEARTBEAT_PID}" 2>/dev/null || true
        wait "${LOCK_HEARTBEAT_PID}" 2>/dev/null || true
        LOCK_HEARTBEAT_PID=""
    fi
    if [ -d "${LOCK_DIR}" ] && [ "$(cat "${LOCK_DIR}/owner" 2>/dev/null || true)" = "$$" ]; then
        rm -rf "${LOCK_DIR}"
    fi
}

start_lock_heartbeat() {
    (
        while [ -d "${LOCK_DIR}" ] \
            && [ "$(cat "${LOCK_DIR}/owner" 2>/dev/null || true)" = "$$" ]; do
            touch "${LOCK_DIR}"
            sleep 30
        done
    ) &
    LOCK_HEARTBEAT_PID="$!"
}

stop_lock_heartbeat() {
    if [ -n "${LOCK_HEARTBEAT_PID}" ]; then
        kill "${LOCK_HEARTBEAT_PID}" 2>/dev/null || true
        wait "${LOCK_HEARTBEAT_PID}" 2>/dev/null || true
        LOCK_HEARTBEAT_PID=""
    fi
}

trap cleanup_lock EXIT INT TERM

while true; do
    if mkdir "${LOCK_DIR}" 2>/dev/null; then
        echo "$$" > "${LOCK_DIR}/owner"
        start_lock_heartbeat
        echo "[scheduler] $(date -Iseconds) running php xcat Cron"

        if php xcat Cron; then
            printf '%s\n' "$(date +%s)" > "${HEARTBEAT_FILE}"
            echo "[scheduler] $(date -Iseconds) cron completed"
        else
            status="$?"
            echo "[scheduler] $(date -Iseconds) cron failed with exit code ${status}" >&2
        fi

        stop_lock_heartbeat
        rm -rf "${LOCK_DIR}"
    else
        lock_mtime="$(stat -c %Y "${LOCK_DIR}" 2>/dev/null || echo 0)"
        now="$(date +%s)"

        if [ "${lock_mtime}" != "0" ] && [ $((now - lock_mtime)) -gt "${STALE_AFTER_SECONDS}" ]; then
            echo "[scheduler] $(date -Iseconds) removing stale cron lock" >&2
            rm -rf "${LOCK_DIR}"
        else
            echo "[scheduler] $(date -Iseconds) previous cron run still active, skipping"
        fi
    fi

    now="$(date +%s)"
    sleep_for="$(( INTERVAL_SECONDS - (now % INTERVAL_SECONDS) ))"

    if [ "${sleep_for}" -lt 1 ] || [ "${sleep_for}" -gt "${INTERVAL_SECONDS}" ]; then
        sleep_for="${INTERVAL_SECONDS}"
    fi

    sleep "${sleep_for}"
done
